<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.WorkOrderDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form">

  <Page title="{i18n>wodTitle}" showNavButton="true" navButtonPress="onNavBack">

    <headerContent>
      <ObjectStatus
        text="{detail>/status}"
        state="{= ${detail>/status} === 'PGI_POSTED' || ${detail>/status} === 'GR_POSTED' ? 'Success' : ${detail>/status} === 'FAILED' ? 'Error' : 'Warning'}" />
      <Button text="{i18n>wodSendToWMS}" icon="sap-icon://outbox" press="onSendToWMS" type="Emphasized"
        visible="{= ${detail>/status} === 'RECEIVED'}" />
    </headerContent>

    <content>
      <IconTabBar id="detailTabs" expandable="false">

        <!-- TAB 1: Overview -->
        <items>
          <IconTabFilter text="{i18n>wodOverview}" icon="sap-icon://hint" key="overview">
            <l:Grid defaultSpan="XL6 L6 M12 S12" class="sapUiSmallMarginTop">

              <!-- SAP Info -->
              <Panel headerText="{i18n>wodSAPInfo}">
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" columnsL="2" columnsM="1">
                  <Label text="{i18n>woDeliveryNo}" />
                  <Text text="{detail>/sap_delivery_no}" />
                  <Label text="{i18n>woDeliveryType}" />
                  <Text text="{detail>/sap_delivery_type}" />
                  <Label text="{i18n>wodDocDate}" />
                  <Text text="{detail>/sap_doc_date}" />
                  <Label text="{i18n>woShipTo}" />
                  <Text text="{detail>/sap_ship_to}" />
                  <Label text="{i18n>wodSoldTo}" />
                  <Text text="{detail>/sap_sold_to}" />
                  <Label text="{i18n>woPlant}" />
                  <Text text="{detail>/plant_code}" />
                  <Label text="{i18n>woType}" />
                  <ObjectStatus text="{detail>/order_type}"
                    state="{= ${detail>/order_type} === 'OUTBOUND' ? 'Information' : 'Success'}" />
                </f:SimpleForm>
              </Panel>

              <!-- WMS Info -->
              <Panel headerText="{i18n>wodWMSInfo}">
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout" columnsL="2" columnsM="1">
                  <Label text="{i18n>wodWMSOrderID}" />
                  <Text text="{detail>/wms_order_id}" />
                  <Label text="{i18n>woWarehouse}" />
                  <Text text="{detail>/warehouse_code}" />
                  <Label text="{i18n>wodReceivedAt}" />
                  <Text text="{detail>/received_at_fmt}" />
                  <Label text="{i18n>wodSentToWMSAt}" />
                  <Text text="{detail>/sent_to_wms_at_fmt}" />
                  <Label text="{i18n>wodCompletedAt}" />
                  <Text text="{detail>/completed_at_fmt}" />
                  <Label text="{i18n>wodSAPPostedAt}" />
                  <Text text="{detail>/sap_posted_at_fmt}" />
                </f:SimpleForm>
              </Panel>

            </l:Grid>
          </IconTabFilter>

          <!-- TAB 2: Lines -->
          <IconTabFilter text="{i18n>wodLines}" icon="sap-icon://list" key="lines"
            count="{detail>/lineCount}">
            <Table items="{detail>/lines}" autoPopinMode="true">
              <columns>
                <Column importance="High"><Text text="{i18n>wodItem}" /></Column>
                <Column importance="High"><Text text="{i18n>wodMaterial}" /></Column>
                <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>wodBatch}" /></Column>
                <Column importance="High" hAlign="End"><Text text="{i18n>wodRequestedQty}" /></Column>
                <Column importance="High" hAlign="End"><Text text="{i18n>wodPickedQty}" /></Column>
                <Column importance="Low" hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>wodFinalQty}" /></Column>
                <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>wodUoM}" /></Column>
                <Column importance="Low" hAlign="Center" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>wodClosed}" /></Column>
                <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>wodHUSerial}" /></Column>
              </columns>
              <items>
                <ColumnListItem
                  highlight="{= ${detail>wms_picked_qty} &lt; ${detail>sap_requested_qty} ? 'Warning' : 'Success'}">
                  <cells>
                    <Text text="{detail>sap_item_no}" />
                    <ObjectIdentifier title="{detail>sap_material}" text="{detail>sap_material_desc}" />
                    <Text text="{detail>sap_batch}" />
                    <ObjectNumber number="{detail>sap_requested_qty}" unit="{detail>sap_uom}" />
                    <ObjectNumber
                      number="{detail>wms_picked_qty}"
                      state="{= ${detail>wms_picked_qty} &lt; ${detail>sap_requested_qty} ? 'Warning' : 'Success'}" />
                    <ObjectNumber number="{detail>sap_final_qty}" />
                    <Text text="{detail>wms_uom}" />
                    <core:Icon src="{= ${detail>is_closed} ? 'sap-icon://accept' : 'sap-icon://border'}"
                      color="{= ${detail>is_closed} ? '#2b7c2b' : '#999'}" />
                    <Text text="{detail>hu_serial_info}" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>

          <!-- TAB 3: Islemler (Operations) - Uyarlama Tabanli -->
          <IconTabFilter text="{i18n>wodOperations}" icon="sap-icon://action" key="operations"
            count="{detail>/stepCount}">

            <!-- Uyarlama bulunamadi mesaji -->
            <MessageStrip
              text="{i18n>opNoConfig}"
              type="Warning"
              showIcon="true"
              class="sapUiSmallMargin"
              visible="{= !${detail>/hasProcessConfig}}" />

            <!-- Ana icerik: sol liste + sag detay -->
            <l:Grid defaultSpan="XL5 L5 M12 S12" visible="{detail>/hasProcessConfig}">

              <!-- SOL: Islem Adimlari Listesi -->
              <Panel headerText="{i18n>opStepList}">
                <List id="stepList" mode="MultiSelect" items="{detail>/processSteps}"
                  selectionChange="onStepSelectionChange"
                  itemPress="onStepPress">
                  <items>
                    <CustomListItem type="Active" press="onStepPress">
                      <HBox class="sapUiTinyMargin" alignItems="Center">
                        <VBox class="sapUiTinyMarginEnd" width="100%">
                          <Title text="{detail>name}" level="H6" />
                          <HBox alignItems="Center">
                            <core:Icon src="sap-icon://arrow-right" size="0.75rem" color="#666" class="sapUiTinyMarginEnd" />
                            <Text text="{detail>source_system}  \u2192  {detail>target_system}" class="sapUiTinyMarginEnd" />
                          </HBox>
                          <ObjectStatus
                            text="{detail>status}"
                            state="{= ${detail>status} === 'BASARILI' ? 'Success' : ${detail>status} === 'HATALI' ? 'Error' : ${detail>status} === 'ISLENIYOR' ? 'Information' : 'Warning'}"
                            icon="{= ${detail>status} === 'BASARILI' ? 'sap-icon://accept' : ${detail>status} === 'HATALI' ? 'sap-icon://error' : ${detail>status} === 'ISLENIYOR' ? 'sap-icon://synchronize' : 'sap-icon://pending'}" />
                        </VBox>
                      </HBox>
                    </CustomListItem>
                  </items>
                </List>
              </Panel>

              <!-- SAG: Secili Islem Detayi -->
              <Panel headerText="{i18n>opSelectedDetail}">
                <layoutData>
                  <l:GridData span="XL7 L7 M12 S12" />
                </layoutData>

                <!-- Secim yapilmadi mesaji -->
                <MessageStrip
                  text="{i18n>opSelectStep}"
                  type="Information"
                  showIcon="true"
                  class="sapUiSmallMargin"
                  visible="{= !${detail>/selectedStep/name}}" />

                <!-- Secili adim detayi -->
                <VBox visible="{= !!${detail>/selectedStep/name}}">
                  <f:SimpleForm editable="false" layout="ResponsiveGridLayout" columnsL="1" columnsM="1">
                    <Label text="{i18n>opSource}" />
                    <Text text="{detail>/selectedStep/source_system}" />
                    <Label text="{i18n>opTarget}" />
                    <Text text="{detail>/selectedStep/target_system}" />
                    <Label text="{i18n>opDirection}" />
                    <ObjectStatus text="{detail>/selectedStep/direction}"
                      state="{= ${detail>/selectedStep/direction} === 'OUTBOUND' ? 'Information' : 'Success'}"
                      icon="{= ${detail>/selectedStep/direction} === 'OUTBOUND' ? 'sap-icon://outbox' : 'sap-icon://inbox'}" />
                    <Label text="{i18n>opCompany}" />
                    <Text text="{detail>/selectedStep/company_name}" />
                    <Label text="{i18n>opApiUrl}" />
                    <Text text="{detail>/selectedStep/company_api_url}" />
                    <Label text="{i18n>opBapi}" />
                    <Text text="{detail>/selectedStep/bapi_name}" />
                    <Label text="{i18n>opMvtType}" />
                    <Text text="{detail>/selectedStep/mvt_type}" />
                    <Label text="{i18n>opGmCode}" />
                    <Text text="{detail>/selectedStep/gm_code}" />
                    <Label text="{i18n>opStatus}" />
                    <ObjectStatus
                      text="{detail>/selectedStep/status}"
                      state="{= ${detail>/selectedStep/status} === 'BASARILI' ? 'Success' : ${detail>/selectedStep/status} === 'HATALI' ? 'Error' : ${detail>/selectedStep/status} === 'ISLENIYOR' ? 'Information' : 'Warning'}" />
                  </f:SimpleForm>

                  <!-- Isle / Tumunu Isle butonlari -->
                  <HBox class="sapUiSmallMargin">
                    <Button text="{i18n>opProcess}" icon="sap-icon://initiative" press="onProcessSelected" type="Emphasized"
                      class="sapUiTinyMarginEnd" />
                    <Button text="{i18n>opProcessAll}" icon="sap-icon://batch-payments" press="onProcessAll" type="Attention" />
                  </HBox>
                </VBox>

                <!-- Surec ozet bilgileri -->
                <Panel headerText="{i18n>wodMvtInfo}" class="sapUiSmallMarginTop">
                  <f:SimpleForm editable="false" layout="ResponsiveGridLayout" columnsL="2" columnsM="1">
                    <Label text="{i18n>wodProcessType}" />
                    <Text text="{detail>/process_type_desc}" />
                    <Label text="{i18n>gmMvtType}" />
                    <Text text="{detail>/mvt_type}" />
                    <Label text="{i18n>woWarehouse}" />
                    <Text text="{detail>/warehouse_code}" />
                    <Label text="{i18n>cfgCompany}" />
                    <Text text="{detail>/logistics_company}" />
                  </f:SimpleForm>
                </Panel>
              </Panel>

            </l:Grid>

            <!-- Bilgi mesaji -->
            <MessageStrip
              text="{i18n>opStepsInfo}"
              type="Information"
              showIcon="true"
              class="sapUiSmallMargin"
              visible="{detail>/hasProcessConfig}" />

          </IconTabFilter>

          <!-- TAB 4: Transaction History -->
          <IconTabFilter text="{i18n>wodTransactions}" icon="sap-icon://activity-items" key="transactions"
            count="{detail>/txCount}">
            <Table items="{detail>/transactions}" autoPopinMode="true">
              <columns>
                <Column importance="High"><Text text="{i18n>txAction}" /></Column>
                <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txDirection}" /></Column>
                <Column importance="High"><Text text="{i18n>txStatus}" /></Column>
                <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txSAPFunction}" /></Column>
                <Column importance="Medium" hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txDuration}" /></Column>
                <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txRetryCount}" /></Column>
                <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txStarted}" /></Column>
                <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txError}" /></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{detail>action}" />
                    <Text text="{detail>direction}" />
                    <ObjectStatus text="{detail>status}"
                      state="{= ${detail>status} === 'SUCCESS' ? 'Success' : ${detail>status} === 'FAILED' || ${detail>status} === 'DEAD' ? 'Error' : 'Warning'}" />
                    <Text text="{detail>sap_function}" />
                    <ObjectNumber number="{detail>duration_ms}" unit="ms" />
                    <ObjectNumber number="{detail>retry_count}" />
                    <Text text="{detail>started_at_fmt}" />
                    <Text text="{detail>error_message}" maxLines="2" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>

          <!-- TAB 5: Raw Payloads -->
          <IconTabFilter text="{i18n>wodRawData}" icon="sap-icon://syntax" key="raw">
            <l:Grid defaultSpan="XL6 L6 M12 S12">
              <Panel headerText="{i18n>wodSAPRawPayload}">
                <TextArea value="{detail>/sap_raw_payload_str}" rows="20" width="100%" editable="false" growing="true" />
              </Panel>
              <Panel headerText="{i18n>wodWMSRawPayload}">
                <TextArea value="{detail>/wms_raw_payload_str}" rows="20" width="100%" editable="false" growing="true" />
              </Panel>
            </l:Grid>
          </IconTabFilter>

        </items>
      </IconTabBar>
    </content>

  </Page>

</mvc:View>
