<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.Login"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:core="sap.ui.core"
  height="100%">

  <Page showHeader="false" backgroundDesign="Solid" enableScrolling="false">
    <content>
      <FlexBox justifyContent="Center" alignItems="Center" class="sapUiLoginFlex">
        <VBox width="360px" class="sapUiMediumMargin">

          <FlexBox justifyContent="Center" class="sapUiMediumMarginBottom">
            <VBox alignItems="Center">
              <Title text="Redigo Logistics" level="H1" class="sapUiSmallMarginBottom" />
              <Title text="{i18n>appDescription}" level="H5" titleStyle="H5" />
            </VBox>
          </FlexBox>

          <l:VerticalLayout width="100%" class="sapUiContentPadding">
            <MessageStrip
              id="loginError"
              type="Error"
              showIcon="true"
              visible="{login>/errorVisible}"
              text="{login>/errorText}"
              class="sapUiSmallMarginBottom" />

            <Label text="{i18n>loginEmail}" required="true" labelFor="emailInput" />
            <Input id="emailInput"
              value="{login>/email}"
              placeholder="{i18n>loginEmail}"
              type="Email"
              width="100%"
              class="sapUiSmallMarginBottom" />

            <Label text="{i18n>loginPassword}" required="true" labelFor="passwordInput" />
            <Input id="passwordInput"
              value="{login>/password}"
              placeholder="{i18n>loginPassword}"
              type="Password"
              width="100%"
              submit="onLogin"
              class="sapUiSmallMarginBottom" />

            <Link
              text="{i18n>forgotPassword}"
              press="onForgotPassword"
              textAlign="End"
              width="100%"
              class="sapUiSmallMarginBottom" />

            <Button
              text="{i18n>loginButton}"
              press="onLogin"
              type="Emphasized"
              width="100%"
              class="sapUiSmallMarginTop"
              busy="{login>/busy}" />

            <!-- Language Selector -->
            <FlexBox justifyContent="Center" class="sapUiSmallMarginTop">
              <Select id="langSelect"
                selectedKey="{login>/language}"
                change="onLanguageChange"
                width="200px">
                <core:Item key="tr" text="Türkçe" />
                <core:Item key="en" text="English" />
                <core:Item key="de" text="Deutsch" />
                <core:Item key="fr" text="Français" />
                <core:Item key="es" text="Español" />
              </Select>
            </FlexBox>
          </l:VerticalLayout>

          <FlexBox justifyContent="Center" class="sapUiMediumMarginTop">
            <Text text="v1.2" class="sapUiTinyMargin" />
          </FlexBox>

        </VBox>
      </FlexBox>
    </content>
  </Page>

</mvc:View>
