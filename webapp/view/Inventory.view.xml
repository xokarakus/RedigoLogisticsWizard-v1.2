<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.Inventory"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Page title="{i18n>invTitle}" showNavButton="false">

    <headerContent>
      <Button icon="sap-icon://refresh" press="onRefresh" type="Transparent" />
    </headerContent>

    <subHeader>
      <OverflowToolbar>
        <SearchField width="300px" placeholder="{i18n>invSearchPlaceholder}" liveChange="onSearch" />
        <ToolbarSpacer />
        <Select id="warehouseFilter" change="onFilterChange"
          items="{inv>/warehouseOptions}">
          <core:Item key="{inv>key}" text="{inv>text}" />
        </Select>
        <Select id="statusFilter" change="onFilterChange">
          <core:Item key="ALL" text="{i18n>invAllStatus}" />
          <core:Item key="SUCCESS" text="{i18n>txSuccess}" />
          <core:Item key="FAILED" text="{i18n>txFailed}" />
          <core:Item key="PENDING" text="{i18n>txPending}" />
          <core:Item key="RETRYING" text="{i18n>txRetrying}" />
        </Select>
        <ObjectStatus text="{inv>/countText}" state="Information" />
      </OverflowToolbar>
    </subHeader>

    <content>
      <!-- Movement Mappings Summary -->
      <Panel headerText="{i18n>invActiveMappings}" class="sapUiSmallMargin">
        <Table items="{inv>/mappings}" mode="None" autoPopinMode="true">
          <columns>
            <Column importance="High"><Text text="{i18n>invWarehouse}" /></Column>
            <Column importance="High"><Text text="{i18n>invAction}" /></Column>
            <Column importance="High"><Text text="{i18n>invSAPMvtType}" /></Column>
            <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>invDescription}" /></Column>
            <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>invTargetPlant}" /></Column>
            <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>invTargetSLoc}" /></Column>
          </columns>
          <items>
            <ColumnListItem>
              <cells>
                <Text text="{inv>warehouse_code}" />
                <ObjectStatus text="{inv>wms_action_code}" state="Information" />
                <ObjectNumber number="{inv>sap_movement_type}" emphasized="true" />
                <Text text="{inv>description}" />
                <Text text="{inv>sap_to_plant}" />
                <Text text="{inv>sap_to_stor_loc}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </Panel>

      <!-- Recent Inventory Transactions -->
      <Panel headerText="{i18n>invRecentMovements}" class="sapUiSmallMargin">
        <Table
          id="invTxTable"
          items="{inv>/transactions}"
          growing="true"
          growingThreshold="25"
          autoPopinMode="true">

          <columns>
            <Column importance="High"><Text text="{i18n>invAction}" /></Column>
            <Column importance="High"><Text text="{i18n>invMaterial}" /></Column>
            <Column importance="High" hAlign="End"><Text text="{i18n>invQuantity}" /></Column>
            <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>invSAPMvtType}" /></Column>
            <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>invWarehouse}" /></Column>
            <Column importance="High"><Text text="{i18n>txStatus}" /></Column>
            <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>invSAPDoc}" /></Column>
            <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>invTimestamp}" /></Column>
          </columns>

          <items>
            <ColumnListItem
              highlight="{= ${inv>status} === 'SUCCESS' ? 'Success' : ${inv>status} === 'FAILED' ? 'Error' : 'None'}">
              <cells>
                <Text text="{inv>action}" />
                <Text text="{inv>material}" />
                <ObjectNumber number="{inv>quantity}" unit="{inv>uom}" />
                <ObjectNumber number="{inv>sap_movement_type}" emphasized="true" />
                <Text text="{inv>warehouse_code}" />
                <ObjectStatus text="{inv>status}"
                  state="{= ${inv>status} === 'SUCCESS' ? 'Success' : ${inv>status} === 'FAILED' ? 'Error' : 'Warning'}" />
                <Text text="{inv>sap_doc_number}" />
                <Text text="{inv>created_at_fmt}" />
              </cells>
            </ColumnListItem>
          </items>

        </Table>
      </Panel>

    </content>

  </Page>

</mvc:View>
