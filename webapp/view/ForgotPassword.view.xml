<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.ForgotPassword"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  height="100%">

  <Page showHeader="false" backgroundDesign="Solid" enableScrolling="false">
    <content>
      <FlexBox height="100%" justifyContent="Center" alignItems="Center">
        <VBox width="360px" class="sapUiMediumMargin">

          <FlexBox justifyContent="Center" class="sapUiMediumMarginBottom">
            <VBox alignItems="Center">
              <Title text="{i18n>forgotPasswordTitle}" level="H1" class="sapUiSmallMarginBottom" />
              <Text text="{i18n>forgotPasswordDesc}" class="sapUiTinyMarginBottom" />
            </VBox>
          </FlexBox>

          <l:VerticalLayout width="100%" class="sapUiContentPadding">
            <MessageStrip
              id="fpSuccess"
              type="Success"
              showIcon="true"
              visible="{fp>/successVisible}"
              text="{fp>/successText}"
              class="sapUiSmallMarginBottom" />

            <MessageStrip
              id="fpError"
              type="Error"
              showIcon="true"
              visible="{fp>/errorVisible}"
              text="{fp>/errorText}"
              class="sapUiSmallMarginBottom" />

            <Label text="{i18n>loginEmail}" required="true" />
            <Input id="emailInput"
              value="{fp>/email}"
              placeholder="{i18n>loginEmail}"
              type="Email"
              width="100%"
              submit="onSendReset"
              class="sapUiSmallMarginBottom" />

            <Button
              text="{i18n>forgotPasswordSend}"
              press="onSendReset"
              type="Emphasized"
              width="100%"
              class="sapUiSmallMarginTop"
              busy="{fp>/busy}" />

            <Link
              text="{i18n>forgotPasswordBack}"
              press="onBackToLogin"
              class="sapUiMediumMarginTop"
              textAlign="Center"
              width="100%" />
          </l:VerticalLayout>

          <FlexBox justifyContent="Center" class="sapUiMediumMarginTop">
            <Text text="v1.2" class="sapUiTinyMargin" />
          </FlexBox>

        </VBox>
      </FlexBox>
    </content>
  </Page>

</mvc:View>
