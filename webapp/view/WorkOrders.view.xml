<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.WorkOrders"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout">

  <Page title="{i18n>woTitle}" showNavButton="false">

    <headerContent>
      <SegmentedButton id="typeFilter" selectionChange="onTypeFilterChange">
        <items>
          <SegmentedButtonItem text="{i18n>woFilterAll}" key="ALL" />
          <SegmentedButtonItem text="{i18n>woOutbound}" key="OUTBOUND" />
          <SegmentedButtonItem text="{i18n>woInbound}" key="INBOUND" />
        </items>
      </SegmentedButton>
      <Button text="{i18n>woProcessBtn}" icon="sap-icon://initiative" press="onProcessSelected" type="Emphasized" />
      <Button icon="sap-icon://refresh" press="onRefresh" type="Transparent" />
      <Button icon="sap-icon://excel-attachment" text="{i18n>btnExport}" press="onExport" type="Transparent" />
    </headerContent>

    <subHeader>
      <OverflowToolbar>
        <SearchField width="300px" placeholder="{i18n>woSearchPlaceholder}" liveChange="onSearch" />
        <ToolbarSpacer />
        <Select id="warehouseFilter" change="onFilterChange"
          items="{workOrders>/warehouseOptions}">
          <core:Item key="{workOrders>key}" text="{workOrders>text}" />
        </Select>
        <Select id="deliveryTypeFilter" change="onFilterChange"
          items="{workOrders>/deliveryTypeOptions}">
          <core:Item key="{workOrders>key}" text="{workOrders>text}" />
        </Select>
        <Select id="statusFilter" change="onFilterChange">
          <core:Item key="ALL" text="{i18n>woFilterAll}" />
          <core:Item key="RECEIVED" text="{i18n>woReceived}" />
          <core:Item key="SENT_TO_WMS" text="{i18n>woSentToWMS}" />
          <core:Item key="IN_PROGRESS" text="{i18n>woInProgress}" />
          <core:Item key="PARTIALLY_DONE" text="{i18n>woPartiallyDone}" />
          <core:Item key="COMPLETED" text="{i18n>woCompleted2}" />
          <core:Item key="PGI_POSTED" text="{i18n>woPGIPosted}" />
          <core:Item key="GR_POSTED" text="{i18n>woGRPosted}" />
          <core:Item key="FAILED" text="{i18n>woFailed}" />
        </Select>
        <ObjectStatus text="{workOrders>/countText}" state="Information" />
      </OverflowToolbar>
    </subHeader>

    <content>
      <Table
        id="workOrdersTable"
        items="{workOrders>/data}"
        growing="true"
        growingThreshold="25"
        growingScrollToLoad="true"
        mode="MultiSelect"
        selectionChange="onSelectionChange">

        <columns>
          <Column width="140px"><Text text="{i18n>woDeliveryNo}" /></Column>
          <Column width="80px"><Text text="{i18n>woDeliveryType}" /></Column>
          <Column width="100px"><Text text="{i18n>woType}" /></Column>
          <Column width="120px"><Text text="{i18n>woStatus}" /></Column>
          <Column width="120px"><Text text="{i18n>woWarehouse}" /></Column>
          <Column width="100px"><Text text="{i18n>woShipTo}" /></Column>
          <Column width="60px" hAlign="Center"><Text text="{i18n>woLines}" /></Column>
          <Column width="80px"><Text text="{i18n>woPriority}" /></Column>
          <Column><Text text="{i18n>woReceivedAt}" /></Column>
          <Column><Text text="{i18n>woCompletedAt}" /></Column>
        </columns>

        <items>
          <ColumnListItem type="Navigation" press="onRowPress">
            <cells>
              <ObjectIdentifier title="{workOrders>sap_delivery_no}" />
              <Text text="{workOrders>sap_delivery_type}" />
              <ObjectStatus
                text="{workOrders>order_type}"
                state="{= ${workOrders>order_type} === 'OUTBOUND' ? 'Information' : 'Success'}"
                icon="{= ${workOrders>order_type} === 'OUTBOUND' ? 'sap-icon://outbox' : 'sap-icon://inbox'}" />
              <ObjectStatus
                text="{workOrders>status}"
                state="{= ${workOrders>status} === 'PGI_POSTED' || ${workOrders>status} === 'GR_POSTED' || ${workOrders>status} === 'COMPLETED' ? 'Success' : ${workOrders>status} === 'FAILED' || ${workOrders>status} === 'CANCELLED' ? 'Error' : ${workOrders>status} === 'IN_PROGRESS' || ${workOrders>status} === 'PARTIALLY_DONE' ? 'Warning' : 'None'}" />
              <Text text="{workOrders>warehouse_code}" />
              <Text text="{workOrders>sap_ship_to}" />
              <ObjectNumber number="{workOrders>line_count}" />
              <ObjectStatus
                text="{workOrders>priority}"
                state="{= ${workOrders>priority} === 'HIGH' ? 'Error' : ${workOrders>priority} === 'MEDIUM' ? 'Warning' : 'Success'}" />
              <Text text="{workOrders>received_at_fmt}" />
              <Text text="{workOrders>completed_at_fmt}" />
            </cells>
          </ColumnListItem>
        </items>

      </Table>
    </content>

  </Page>

</mvc:View>
