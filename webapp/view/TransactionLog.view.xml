<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.TransactionLog"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Page title="{i18n>txTitle}" showNavButton="false">

    <headerContent>
      <Button icon="sap-icon://refresh" press="onRefresh" type="Transparent" />
    </headerContent>

    <subHeader>
      <OverflowToolbar>
        <SearchField width="300px" placeholder="{i18n>txSearchPlaceholder}" liveChange="onSearch" />
        <ToolbarSpacer />
        <Select id="actionFilter" change="onFilterChange"
          items="{txLog>/actionOptions}">
          <core:Item key="{txLog>key}" text="{txLog>text}" />
        </Select>
        <Select id="directionFilter" change="onFilterChange">
          <core:Item key="ALL" text="{i18n>txAllDirections}" />
          <core:Item key="SAP_TO_WMS" text="{i18n>txSAPtoWMS}" />
          <core:Item key="WMS_TO_SAP" text="{i18n>txWMStoSAP}" />
        </Select>
        <Select id="statusFilter" change="onFilterChange">
          <core:Item key="ALL" text="{i18n>txAllStatus}" />
          <core:Item key="PENDING" text="{i18n>txPending}" />
          <core:Item key="SUCCESS" text="{i18n>txSuccess}" />
          <core:Item key="FAILED" text="{i18n>txFailed}" />
          <core:Item key="RETRYING" text="{i18n>txRetrying}" />
          <core:Item key="DEAD" text="{i18n>txDead}" />
        </Select>
        <ObjectStatus text="{txLog>/countText}" state="Information" />
      </OverflowToolbar>
    </subHeader>

    <content>
      <Table
        id="txTable"
        items="{txLog>/data}"
        growing="true"
        growingThreshold="50"
        growingScrollToLoad="true"
        autoPopinMode="true">

        <columns>
          <Column importance="High"><Text text="{i18n>txAction}" /></Column>
          <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txDirection}" /></Column>
          <Column importance="High"><Text text="{i18n>txStatus}" /></Column>
          <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txSAPFunction}" /></Column>
          <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txSAPDoc}" /></Column>
          <Column importance="Medium" hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txDuration}" /></Column>
          <Column importance="Low" hAlign="Center" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txRetryCount}" /></Column>
          <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txStarted}" /></Column>
          <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txError}" /></Column>
        </columns>

        <items>
          <ColumnListItem
            highlight="{= ${txLog>status} === 'SUCCESS' ? 'Success' : ${txLog>status} === 'FAILED' || ${txLog>status} === 'DEAD' ? 'Error' : ${txLog>status} === 'RETRYING' ? 'Warning' : 'None'}"
            type="Active"
            press="onTxPress">
            <cells>
              <Text text="{txLog>action}" />
              <ObjectStatus
                text="{txLog>direction}"
                state="{= ${txLog>direction} === 'SAP_TO_WMS' ? 'Information' : 'Success'}" />
              <ObjectStatus
                text="{txLog>status}"
                state="{= ${txLog>status} === 'SUCCESS' ? 'Success' : ${txLog>status} === 'FAILED' || ${txLog>status} === 'DEAD' ? 'Error' : ${txLog>status} === 'RETRYING' ? 'Warning' : 'None'}" />
              <Text text="{txLog>sap_function}" />
              <Text text="{txLog>sap_doc_number}" />
              <ObjectNumber number="{txLog>duration_ms}" unit="ms" />
              <ObjectNumber number="{txLog>retry_count}" />
              <Text text="{txLog>started_at_fmt}" />
              <Text text="{txLog>error_message}" maxLines="1" />
            </cells>
          </ColumnListItem>
        </items>

      </Table>
    </content>

  </Page>

</mvc:View>
