<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.DeadLetterQueue"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout">

  <Page title="{i18n>dlqTitle}" showNavButton="false">

    <headerContent>
      <Button icon="sap-icon://refresh" press="onRefresh" type="Transparent" />
    </headerContent>

    <subHeader>
      <OverflowToolbar>
        <SearchField width="300px" placeholder="{i18n>dlqSearchPlaceholder}" liveChange="onSearch" />
        <ToolbarSpacer />
        <Select id="actionFilter" change="onFilterChange"
          items="{dlq>/actionOptions}">
          <core:Item key="{dlq>key}" text="{dlq>text}" />
        </Select>
        <ObjectStatus text="{dlq>/countText}" state="Error" />
      </OverflowToolbar>
    </subHeader>

    <content>
      <Table
        id="dlqTable"
        items="{dlq>/data}"
        growing="true"
        growingThreshold="25"
        mode="SingleSelectMaster"
        autoPopinMode="true"
        selectionChange="onItemSelect">

        <columns>
          <Column importance="High"><Text text="{i18n>txAction}" /></Column>
          <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txSAPFunction}" /></Column>
          <Column importance="High"><Text text="{i18n>dlqDelivery}" /></Column>
          <Column importance="Low" hAlign="Center" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>txRetryCount}" /></Column>
          <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>dlqErrorMessage}" /></Column>
          <Column importance="Medium" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>txStarted}" /></Column>
          <Column importance="High" hAlign="Center"><Text text="{i18n>dlqActions}" /></Column>
        </columns>

        <items>
          <ColumnListItem highlight="Error">
            <cells>
              <Text text="{dlq>action}" />
              <Text text="{dlq>sap_function}" />
              <Text text="{dlq>delivery_no}" />
              <ObjectNumber number="{dlq>retry_count}" state="Error" />
              <Text text="{dlq>error_message}" maxLines="2" />
              <Text text="{dlq>started_at_fmt}" />
              <HBox justifyContent="Center">
                <Button text="{i18n>dlqEdit}" icon="sap-icon://edit" press="onEditPayload" type="Transparent"
                  class="sapUiTinyMarginEnd" />
                <Button text="{i18n>dlqReplay}" icon="sap-icon://refresh" press="onReplay" type="Emphasized"
                  class="sapUiTinyMarginEnd" />
                <Button text="{i18n>dlqDiscard}" icon="sap-icon://delete" press="onDiscard" type="Reject" />
              </HBox>
            </cells>
          </ColumnListItem>
        </items>

      </Table>

      <!-- Edit Payload Dialog (shown on Edit press) -->
      <l:VerticalLayout id="editSection" visible="{dlq>/editVisible}" class="sapUiSmallMargin" width="100%">
        <Panel headerText="{i18n>dlqEditPayloadHeader}">
          <l:Grid defaultSpan="XL6 L6 M12 S12">
            <Panel headerText="{i18n>dlqOriginalPayload}">
              <TextArea value="{dlq>/selectedOriginal}" rows="15" width="100%" editable="false" />
            </Panel>
            <Panel headerText="{i18n>dlqEditedPayload}">
              <TextArea id="editedPayload" value="{dlq>/selectedEdited}" rows="15" width="100%" editable="true" />
            </Panel>
          </l:Grid>
          <OverflowToolbar>
            <ToolbarSpacer />
            <Button text="{i18n>cfgCancel}" press="onCancelEdit" />
            <Button text="{i18n>dlqSaveAndReplay}" press="onSaveAndReplay" type="Emphasized" />
          </OverflowToolbar>
        </Panel>
      </l:VerticalLayout>

    </content>

  </Page>

</mvc:View>
