<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.DbCockpit"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:t="sap.ui.table"
  height="100%">

  <Page title="{i18n>dbCockpitTitle}" showNavButton="false" enableScrolling="false" accessibleRole="Main">
    <content>
      <HBox height="100%" width="100%">

        <!-- Sol Panel: Tablo Listesi (sabit 280px) -->
        <VBox width="320px" height="100%" class="sapUiTinyMarginEnd">
          <Toolbar class="sapUiSizeCompact">
            <core:Icon src="sap-icon://database" class="sapUiTinyMarginEnd" />
            <Title text="{i18n>dbCockpitTables}" level="H5" />
            <ToolbarSpacer />
            <ObjectStatus id="tableCount" state="Information" />
          </Toolbar>
          <SearchField width="100%" placeholder="{i18n>dbCockpitTableSearch}" liveChange="onTableSearch"
            class="sapUiTinyMargin" />
          <ScrollContainer height="calc(100vh - 180px)" width="100%" vertical="true" horizontal="false">
            <List id="tableList" items="{dbc>/filteredTables}" mode="SingleSelectMaster"
              selectionChange="onTableSelect" growing="true" growingThreshold="50"
              class="sapUiSizeCompact">
              <items>
                <ObjectListItem title="{dbc>name}" icon="sap-icon://table-view" type="Active"
                  number="{dbc>row_count}" numberUnit="rows"
                  numberState="{= ${dbc>row_count} > 1000 ? 'Warning' : ${dbc>row_count} > 0 ? 'Success' : 'None' }" />
              </items>
            </List>
          </ScrollContainer>
        </VBox>

        <!-- Sag Panel: Veri + SQL + Iliskiler -->
        <VBox height="100%" class="sapUiSizeCompact">
          <layoutData>
            <FlexItemData growFactor="1" />
          </layoutData>
          <IconTabBar id="mainTabs" expandable="false" stretchContentHeight="true">
            <items>

              <!-- Tab 1: Tablo Verisi -->
              <IconTabFilter text="{i18n>dbCockpitTableData}" icon="sap-icon://table-view" key="data">
                <t:Table id="dataTable" visibleRowCountMode="Auto" alternateRowColors="true"
                  enableBusyIndicator="true" selectionMode="None" minAutoRowCount="5">
                  <t:extension>
                    <OverflowToolbar>
                      <Title text="{dbc>/selectedTable}" />
                      <ToolbarSpacer />
                      <Button icon="sap-icon://hint" tooltip="{i18n>dbCockpitColumns}" press="onShowColumnInfo" type="Transparent" />
                      <Button icon="sap-icon://download" tooltip="CSV" press="onExport" type="Transparent" />
                      <Button icon="sap-icon://refresh" press="onRefreshData" type="Transparent" />
                    </OverflowToolbar>
                  </t:extension>
                </t:Table>
                <OverflowToolbar>
                  <Button icon="sap-icon://navigation-left-arrow" press="onPrevPage" enabled="{dbc>/hasPrev}" />
                  <Text text="{dbc>/pageInfo}" />
                  <Button icon="sap-icon://navigation-right-arrow" press="onNextPage" enabled="{dbc>/hasNext}" />
                </OverflowToolbar>
              </IconTabFilter>

              <!-- Tab 2: SQL Sorgusu -->
              <IconTabFilter text="{i18n>dbCockpitSqlQuery}" icon="sap-icon://syntax" key="sql">
                <VBox class="sapUiSmallMargin">
                  <OverflowToolbar class="sapUiTinyMarginBottom">
                    <core:Icon src="sap-icon://save" class="sapUiTinyMarginEnd" />
                    <Select id="savedQuerySelect" width="280px" change="onLoadSavedQuery"
                      items="{dbc>/savedQueries}">
                      <core:Item key="{dbc>key}" text="{dbc>name}" />
                    </Select>
                    <Button icon="sap-icon://save" tooltip="{i18n>dbCockpitSaveQuery}" press="onSaveQuery" type="Transparent" />
                    <Button icon="sap-icon://delete" tooltip="{i18n>dbCockpitDeleteQuery}" press="onDeleteQuery" type="Transparent" />
                    <ToolbarSpacer />
                    <ObjectStatus id="savedQueryCount" state="Information" />
                  </OverflowToolbar>
                  <TextArea id="sqlEditor" rows="4" width="100%" growing="true"
                    placeholder="{i18n>dbCockpitSqlPlaceholder}" />
                  <HBox class="sapUiSmallMarginTop" alignItems="Center">
                    <Button text="{i18n>dbCockpitExecute}" icon="sap-icon://media-play"
                      type="Emphasized" press="onExecuteQuery" />
                    <ObjectStatus id="queryStatus" class="sapUiSmallMarginBegin" />
                  </HBox>
                </VBox>
                <t:Table id="queryResultTable" visibleRowCountMode="Auto" alternateRowColors="true"
                  enableBusyIndicator="true" selectionMode="None" minAutoRowCount="5">
                  <t:extension>
                    <OverflowToolbar>
                      <Title text="{dbc>/queryRowCount}" />
                      <ToolbarSpacer />
                      <Button icon="sap-icon://download" tooltip="CSV" press="onExportQuery" type="Transparent" />
                    </OverflowToolbar>
                  </t:extension>
                </t:Table>
              </IconTabFilter>

              <!-- Tab 3: Iliskiler (Gorsel) -->
              <IconTabFilter text="{i18n>dbCockpitRelationships}" icon="sap-icon://chain-link" key="rel">
                <VBox height="100%">
                  <OverflowToolbar>
                    <SearchField id="relSearch" width="300px" placeholder="{i18n>dbCockpitTableSearch}" liveChange="onRelationshipSearch" />
                    <ToolbarSpacer />
                    <ObjectStatus id="relStats" />
                    <Button icon="sap-icon://refresh" press="onRefreshRelationships" type="Transparent" />
                  </OverflowToolbar>
                  <ScrollContainer width="100%" vertical="true" horizontal="false" height="calc(100vh - 200px)">
                    <VBox id="relContainer" class="sapUiSmallMargin" />
                  </ScrollContainer>
                </VBox>
              </IconTabFilter>

            </items>
          </IconTabBar>
        </VBox>

      </HBox>
    </content>
  </Page>

</mvc:View>
