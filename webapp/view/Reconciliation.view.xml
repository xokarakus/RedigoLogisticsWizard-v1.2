<mvc:View
  controllerName="com.redigo.logistics.cockpit.controller.Reconciliation"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Page title="{i18n>recTitle}" showNavButton="false" accessibleRole="Main">

    <headerContent>
      <Button text="{i18n>recRunNow}" icon="sap-icon://synchronize" press="onRunNow" type="Emphasized" />
      <Button icon="sap-icon://refresh" press="onRefresh" type="Transparent" />
    </headerContent>

    <subHeader>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Select id="warehouseFilter" change="onFilterChange"
          items="{recon>/warehouseOptions}">
          <core:Item key="{recon>key}" text="{recon>text}" />
        </Select>
        <Select id="statusFilter" change="onFilterChange">
          <core:Item key="ALL" text="{i18n>recAllStatus}" />
          <core:Item key="OPEN" text="Open" />
          <core:Item key="COMPLETED" text="{i18n>woCompleted2}" />
          <core:Item key="REVIEWED" text="{i18n>recMarkReviewed}" />
        </Select>
        <ObjectStatus text="{recon>/countText}" state="Information" />
      </OverflowToolbar>
    </subHeader>

    <content>
      <Table
        id="recTable"
        items="{recon>/data}"
        growing="true"
        growingThreshold="20"
        autoPopinMode="true">

        <columns>
          <Column importance="High"><Text text="{i18n>recRunDate}" /></Column>
          <Column importance="High"><Text text="{i18n>recWarehouse}" /></Column>
          <Column importance="Medium" hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>recSAPOpen}" /></Column>
          <Column importance="Medium" hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>recWMSOpen}" /></Column>
          <Column importance="High" hAlign="End"><Text text="{i18n>recDiscrepancies}" /></Column>
          <Column importance="High"><Text text="{i18n>recStatus}" /></Column>
          <Column importance="Low" minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>recReviewedBy}" /></Column>
          <Column importance="High" hAlign="Center"><Text text="{i18n>recActions}" /></Column>
        </columns>

        <items>
          <ColumnListItem
            highlight="{= ${recon>discrepancy_count} > 0 ? 'Error' : 'Success'}">
            <cells>
              <Text text="{recon>run_date}" />
              <Text text="{recon>warehouse_code}" />
              <ObjectNumber number="{recon>total_sap_open}" />
              <ObjectNumber number="{recon>total_wms_open}" />
              <ObjectNumber
                number="{recon>discrepancy_count}"
                state="{= ${recon>discrepancy_count} > 0 ? 'Error' : 'Success'}" />
              <ObjectStatus text="{recon>status}"
                state="{= ${recon>status} === 'REVIEWED' ? 'Success' : ${recon>status} === 'COMPLETED' ? 'Warning' : 'None'}" />
              <Text text="{recon>reviewed_by}" />
              <HBox justifyContent="Center">
                <Button text="{i18n>recDetails}" icon="sap-icon://detail-view" press="onViewDetails" type="Transparent" />
                <Button text="{i18n>recMarkReviewed}" press="onMarkReviewed" type="Transparent"
                  visible="{= ${recon>status} !== 'REVIEWED'}" />
              </HBox>
            </cells>
          </ColumnListItem>
        </items>

      </Table>
    </content>

  </Page>

</mvc:View>
