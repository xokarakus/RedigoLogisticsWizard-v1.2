# ======================
# Redigo Logistics Wizard v1.2
# ======================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redigo_v12
DB_USER=redigo
DB_PASSWORD=changeme
DB_POOL_SIZE=10

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SAP RFC Connection
SAP_ASHOST=sap-server.local
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=RFC_REDIGO
SAP_PASSWORD=changeme
SAP_LANG=EN
SAP_POOL_SIZE=5
SAP_MAX_CONCURRENCY=5

# Logging
LOG_LEVEL=info

# Cron Schedules
CRON_DELIVERY_INGEST=*/5 * * * *
CRON_RECONCILIATION=0 3 * * *
CRON_ARCHIVE_DAYS=90
